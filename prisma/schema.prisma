// Prisma Schema - Nexora ERP MVP
// All models now include isActive for soft delete handling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum UserRole {
  ADMIN
  MANAGER
  SELLER
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum AccountingEntryType {
  INCOME
  EXPENSE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  CANCEL
  COMPLETE
  RESTORE
}

//
// AUTH
//

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password String
  role         UserRole @default(SELLER)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  sales     Sale[]
  auditLogs AuditLog[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Session {
  id               Int           @id @default(autoincrement())
  userId           Int
  refreshTokenHash String        @unique
  userAgent        String?
  ipAddress        String?
  status           SessionStatus @default(ACTIVE)
  expiresAt        DateTime
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  isActive         Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([isActive])
  @@map("sessions")
}

//
// CRM
//

model Client {
  id        Int     @id @default(autoincrement())
  nombre    String
  telefono  String?
  email     String?
  direccion String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@index([isActive])
  @@map("clients")
}

model Supplier {
  id       Int     @id @default(autoincrement())
  nombre   String
  telefono String?
  email    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@index([isActive])
  @@map("suppliers")
}

//
// PRODUCTS
//

model Product {
  id       Int     @id @default(autoincrement())
  nombre   String
  sku      String  @unique
  precio   Decimal @db.Decimal(12, 2)
  costo    Decimal @db.Decimal(12, 2)
  stock    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  movements     InventoryMovement[]

  @@index([sku])
  @@index([isActive])
  @@map("products")
}

//
// SALES
//

model Sale {
  id       Int        @id @default(autoincrement())
  userId   Int?
  clientId Int?
  total    Decimal    @db.Decimal(12, 2)
  status   SaleStatus @default(DRAFT)
  isActive Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  items             SaleItem[]
  accountingEntries AccountingEntry[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([isActive])
  @@map("sales")
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  saleId     Int
  productId  Int
  cantidad   Int
  precioUnit Decimal @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@index([isActive])
  @@map("sale_items")
}

//
// PURCHASES
//

model Purchase {
  id         Int            @id @default(autoincrement())
  supplierId Int?
  total      Decimal        @db.Decimal(12, 2)
  status     PurchaseStatus @default(PENDING)
  isActive   Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  items             PurchaseItem[]
  accountingEntries AccountingEntry[]

  @@index([supplierId])
  @@index([status])
  @@index([isActive])
  @@map("purchases")
}

model PurchaseItem {
  id         Int     @id @default(autoincrement())
  purchaseId Int
  productId  Int
  cantidad   Int
  precioUnit Decimal @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@index([isActive])
  @@map("purchase_items")
}

//
// INVENTORY
//

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  tipo      MovementType
  cantidad  Int
  motivo    String?
  isActive  Boolean      @default(true)

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([tipo])
  @@index([isActive])
  @@map("inventory_movements")
}

//
// ACCOUNTING
//

model AccountingEntry {
  id          Int                 @id @default(autoincrement())
  tipo        AccountingEntryType
  monto       Decimal             @db.Decimal(12, 2)
  descripcion String

  saleId     Int?
  purchaseId Int?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale     Sale?     @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([tipo])
  @@index([saleId])
  @@index([purchaseId])
  @@index([isActive])
  @@map("accounting_entries")
}

//
// AUDIT
//

model AuditLog {
  id Int @id @default(autoincrement())

  userId Int?
  action AuditAction

  entity   String
  entityId Int?

  description String?

  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
